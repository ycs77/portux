{
  "name": "portux",
  "version": "1.3.0",
  "description": "A TUI dashboard CLI to browse ports, spot what's occupied, and pick a free one with ease.",
  "keywords": [
    "cli",
    "dashboard",
    "ink",
    "netstat",
    "port",
    "ports",
    "tui"
  ],
  "homepage": "https://github.com/ycs77/portux",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ycs77/portux.git"
  },
  "bin": {
    "portux": "./bin/portux.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "scripts": {
    "build": "tsdown",
    "lint": "oxlint",
    "fmt": "oxfmt",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "check": "pnpm lint && pnpm fmt --check && pnpm typecheck && pnpm test --run",
    "update-actions": "actionspack update",
    "release": "bumpp --commit \"Release v%s\"",
    "prepack": "pnpm build"
  },
  "dependencies": {
    "cac": "^7.0.0",
    "find-process": "^2.1.1",
    "ink": "^7.1.0",
    "node-netstat": "^1.9.0",
    "ps-list": "^9.0.0",
    "react": "^19.2.7"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@types/node-netstat": "^1.8.4",
    "@types/react": "^19.2.17",
    "actionspack": "^0.1.5",
    "bumpp": "^11.1.0",
    "ink-testing-library": "^4.0.0",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "oxlint-tsgolint": "^0.23.0",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@11.9.0"
}
